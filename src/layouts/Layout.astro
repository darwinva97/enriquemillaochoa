---
// Fuentes autohospedadas (sin dependencia de Google Fonts): solo el eje de
// peso; el navegador descarga únicamente el subset latin por unicode-range.
import '@fontsource-variable/inter/wght.css';
import '@fontsource-variable/plus-jakarta-sans/wght.css';

interface Props {
  title: string;
  description?: string;
  image?: string; // URL (absoluta o relativa) para og:image / twitter:image
  type?: 'website' | 'article';
}

const {
  title,
  description = 'Portal comunitario del AA.HH. Enrique Milla Ochoa, Los Olivos, Lima, Peru',
  image,
  type = 'website',
} = Astro.props;
const currentPath = Astro.url.pathname;

const tituloCompleto = `${title} | AA.HH. Enrique Milla Ochoa`;
const ogImage = image ? new URL(image, Astro.url).href : undefined;

const navLinks = [
  { href: '/', label: 'Inicio' },
  { href: '/historia', label: 'Historia' },
  { href: '/noticias', label: 'Noticias' },
  { href: '/negocios', label: 'Negocios' },
  { href: '/lugares', label: 'Lugares' },
  { href: '/mapa', label: 'Mapa' },
  { href: '/foros', label: 'Foros' },
  { href: '/curiosidades', label: 'Curiosidades' },
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={Astro.url.href} />
    <title>{tituloCompleto}</title>

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={tituloCompleto} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:site_name" content="Enrique Milla Ochoa" />
    <meta property="og:locale" content="es_PE" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter -->
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={tituloCompleto} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="site-logo">
          <span class="logo-badge">EMO</span>
          <span class="logo-text">Enrique Milla Ochoa</span>
        </a>
        <button
          class="menu-toggle"
          id="menuToggle"
          aria-label="Abrir menú"
          aria-controls="mainNav"
          aria-expanded="false"
        >
          <span class="menu-toggle-bar"></span>
          <span class="menu-toggle-bar"></span>
          <span class="menu-toggle-bar"></span>
        </button>
        <nav class="main-nav" id="mainNav">
          {navLinks.map(link => (
            <a href={link.href} class:list={[{ active: currentPath === link.href || (link.href !== '/' && currentPath.startsWith(link.href)) }]}>
              {link.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <script>
      const toggle = document.getElementById('menuToggle');
      const nav = document.getElementById('mainNav');
      toggle?.addEventListener('click', () => {
        const open = nav?.classList.toggle('open');
        toggle.classList.toggle('is-open', open);
        toggle.setAttribute('aria-expanded', String(!!open));
        toggle.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
      });
    </script>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-col">
          <h4>AA.HH. Enrique Milla Ochoa</h4>
          <p>Portal comunitario del Asentamiento Humano Arq. Enrique Milla Ochoa, distrito de Los Olivos, Lima Norte, Peru.</p>
        </div>
        <div class="footer-col">
          <h4>Secciones</h4>
          {navLinks.map(link => (
            <a href={link.href} style="display:block">{link.label}</a>
          ))}
        </div>
        <div class="footer-col">
          <h4>Ubicacion</h4>
          <p>
            Distrito de Los Olivos<br/>
            Lima Norte, Lima<br/>
            Peru
          </p>
          <p style="margin-top:0.5rem; font-size:0.82rem;">
            Creado el 4 de abril de 1989<br/>
            Ley N.° 25017
          </p>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2026 Portal Comunitario Enrique Milla Ochoa. Hecho con amor por la comunidad.</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
