---
import Layout from '../../layouts/Layout.astro';

const { env } = Astro.locals.runtime;
const db = env.DB;

const { results: threads } = await db.prepare(`
  SELECT t.*, COUNT(r.id) as reply_count
  FROM threads t
  LEFT JOIN replies r ON r.thread_id = t.id
  GROUP BY t.id
  ORDER BY t.created_at DESC
`).all();
---

<Layout title="Foros" description="Foro comunitario del AA.HH. Enrique Milla Ochoa">
  <section class="page-hero">
    <h1>Foros de <span>Enrique Milla Ochoa</span></h1>
    <p>Espacio de dialogo y participacion vecinal</p>
  </section>

  <section class="section">
    <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:1rem; margin-bottom:1.5rem;">
      <div>
        <h2 class="section-title">Temas recientes</h2>
        <p class="section-subtitle" style="margin-bottom:0;">Conversa con tus vecinos sobre lo que importa</p>
      </div>
      <a href="/foros/nuevo" class="btn-primary">Crear nuevo tema</a>
    </div>

    {threads.length === 0 && (
      <div class="highlight-box">
        <h3>Aun no hay temas</h3>
        <p>Se el primero en iniciar una conversacion. Haz clic en "Crear nuevo tema" para empezar.</p>
      </div>
    )}

    {(threads as any[]).map(t => (
      <a href={`/foros/${t.id}`} class="forum-thread">
        <div class="forum-icon">💬</div>
        <div style="flex:1;">
          <h3>{t.title}</h3>
          <p>{t.content.length > 150 ? t.content.slice(0, 150) + '...' : t.content}</p>
          <div class="forum-meta">
            Por {t.author} &middot; {t.reply_count} respuesta{t.reply_count !== 1 ? 's' : ''} &middot; {t.category} &middot; {t.created_at}
          </div>
        </div>
      </a>
    ))}
  </section>
</Layout>

<style>
  .btn-primary {
    display: inline-block;
    background: var(--green-700);
    color: var(--white);
    padding: 0.7rem 1.5rem;
    border-radius: var(--radius);
    font-weight: 600;
    font-size: 0.9rem;
    transition: background 0.2s;
  }
  .btn-primary:hover {
    background: var(--green-900);
    color: var(--white);
  }
  a.forum-thread {
    color: inherit;
    text-decoration: none;
  }
  a.forum-thread:hover {
    border-left-color: var(--yellow-500);
  }
  a.forum-thread:hover h3 {
    color: var(--green-700);
  }
</style>
