---
// Ruta antigua por id numérico. Redirige al nuevo slug dentro de /noticias.
export const prerender = false;
const { env } = Astro.locals.runtime;
const { id } = Astro.params;

const row = (await env.DB.prepare("SELECT slug FROM alert_news WHERE id=? AND status='published'")
  .bind(id)
  .first()) as { slug?: string } | null;

return Astro.redirect(row?.slug ? `/noticias/${row.slug}` : '/noticias', 301);
---
